{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/monthly-reset",
      "schedule": "0 0 1 * *"
    },
    {
      "path": "/api/cron/re-engagement",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/hard-delete",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 8 * * *"
    }
  ]
}
